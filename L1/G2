#include <stdio.h>

int main()
{
    int num1, num2, num3;
    
    
    scanf("%d %d %d", &num1, &num2, &num3);

    if (num1<=0  || num2<=0 || num3<=0)
    {
        printf("Invalid");
    }
    else
    {
        if (num1+num2>num3 && num1+num3>num2 && num2+num3>num1)
        {
            if(num1==num2 && num2==num3)
            {
                printf("Equilateral");
            }
            else if(num1==num2 || num2==num3 || num1==num3)
            {
                printf("Isosceles");
            }
            else
            {
                printf("Scalene");
            }
            
            
        }
        else
        {
            printf("Invalid");
        }
        
    }
    

    return 0;

}
